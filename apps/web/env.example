# =============================================================================
# Job Alerter - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# -----------------------------------------------------------------------------
# NextAuth.js Configuration
# -----------------------------------------------------------------------------

# Required: Secret used to encrypt tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-super-secret-key-here

# Required: Full URL of your application (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAuth Providers
# At least one provider must be configured
# -----------------------------------------------------------------------------

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Create at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------

# Connection string from Neon dashboard
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# AI Service
# -----------------------------------------------------------------------------

# AI Provider: openai | anthropic | groq | local
# AI_PROVIDER=openai

# OpenAI API Key
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
# SENTRY_DSN=https://...

# Axiom for centralized logging
# AXIOM_TOKEN=...
# AXIOM_DATASET=job-alerter
